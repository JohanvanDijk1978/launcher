# ─── Wallet ───────────────────────────────────────────────
WALLET_PATH=data/wallet.json

# ─── Reddit API ───────────────────────────────────────────
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=viral-launcher/1.0

# ─── AI Generation ────────────────────────────────────────
# OpenAI — for coin name/ticker generation
OPENAI_API_KEY=sk-...

# Replicate — for coin image generation (SDXL)
REPLICATE_API_TOKEN=r8_...

# ─── Solana ───────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional: use a faster paid RPC like Helius or QuickNode
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...

# ─── Telegram Bot ─────────────────────────────────────────
# Create bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
# Get your chat ID: message @userinfobot
TELEGRAM_CHAT_ID=your_chat_id

# ─── Virality Thresholds ──────────────────────────────────
MIN_VIRALITY_SCORE=0.65
POLL_INTERVAL=60

# ─── SOL Spend Limits ─────────────────────────────────────
BASE_SOL=0.1
MAX_SOL=1.0

# ─── Nitter Instances (comma-separated) ───────────────────
# NITTER_INSTANCES=https://nitter.poast.org,https://nitter.privacydev.net
